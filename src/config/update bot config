/** Parse a hex color string like "#RRGGBB" into an integer, or return the fallback integer. */
function _hexToInt(hex, fallback) {
  const parsed = parseInt(hex.replace("#", ""), 16);
  return Number.isFinite(parsed) ? parsed : fallback;
}

const _fallbackColorInt = 0x99AAB5;

export function getColor(path, fallback = "#99AAB5") {
  const fallbackInt = typeof fallback === "number"
    ? fallback
    : _hexToInt(fallback, _fallbackColorInt);

  if (typeof path === "number") return path;

  // Direct hex string — validate the parsed result
  if (typeof path === "string" && path.startsWith("#")) {
    return _hexToInt(path, fallbackInt);
  }

  try {
    const result = path
      .split(".")
      .reduce(
        (obj, key) => (obj && obj[key] !== undefined ? obj[key] : undefined),
        botConfig.embeds.colors,
      );
    if (typeof result === "string" && result.startsWith("#")) {
      return _hexToInt(result, fallbackInt);
    }
    // If the resolved value is already a number, use it; otherwise fall back
    return (typeof result === "number" && Number.isFinite(result))
      ? result
      : fallbackInt;
  } catch {
    return fallbackInt;
  }
}

export function getRandomColor() {
  try {
    const colors = Object.values(botConfig.embeds.colors).flatMap((color) =>
      typeof color === "string" ? [color] : Object.values(color).filter(v => typeof v === "string"),
    );
    if (!colors.length) return "#99AAB5";
    return colors[Math.floor(Math.random() * colors.length)];
  } catch {
    return "#99AAB5";
  }
}

export default botConfig;
