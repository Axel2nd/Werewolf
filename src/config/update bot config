// =============================================================================
// CONFIG VALIDATION
// Safe for Railway + GitHub deploys:
// - Never crashes on missing optional vars.
// - Accepts POSTGRES_URL (Railway) OR individual POSTGRES_HOST/USER/PASSWORD.
// - Validates werewolf config structure fully.
// - Wraps everything in try/catch so a bad config logs clearly, not silently.
// =============================================================================
export function validateConfig(config) {
  const errors = [];
  const warnings = [];

  try {
    // ── Discord token ──
    if (!process.env.DISCORD_TOKEN && !process.env.TOKEN) {
      errors.push("DISCORD_TOKEN (or TOKEN) is required — set it in Railway Variables.");
    }

    if (!process.env.CLIENT_ID) {
      errors.push("CLIENT_ID is required — set it in Railway Variables.");
    }

    // ── Database (production only) ──
    // Railway provides POSTGRES_URL automatically when a Postgres plugin is added.
    // Accepts POSTGRES_URL alone, or the individual POSTGRES_HOST/USER/PASSWORD vars.
    if (process.env.NODE_ENV === 'production') {
      const hasUrl = !!process.env.POSTGRES_URL;
      const hasIndividual =
        !!process.env.POSTGRES_HOST &&
        !!process.env.POSTGRES_USER &&
        !!process.env.POSTGRES_PASSWORD;

      if (!hasUrl && !hasIndividual) {
        errors.push(
          "Database connection missing in production. " +
          "Set POSTGRES_URL (recommended for Railway) or POSTGRES_HOST + POSTGRES_USER + POSTGRES_PASSWORD."
        );
      }
    }

    // ── Werewolf config (only if feature is enabled) ──
    if (config?.features?.werewolf) {
      const ww = config.werewolf;

      if (!ww || typeof ww !== 'object') {
        errors.push("werewolf config block is missing or invalid.");
      } else {

        // Player limits
        if (typeof ww.minPlayers !== 'number' || ww.minPlayers < 4) {
          errors.push("werewolf.minPlayers must be a number >= 4.");
        }
        if (typeof ww.maxPlayers !== 'number' || ww.maxPlayers < (ww.minPlayers ?? 4)) {
          errors.push("werewolf.maxPlayers must be a number >= werewolf.minPlayers.");
        }

        // Required sections
        const requiredSections = ['timers', 'lobby', 'roles', 'roleDistribution', 'voting', 'channels', 'dm', 'narrator', 'rewards', 'lovers'];
        for (const section of requiredSections) {
          if (!ww[section] || typeof ww[section] !== 'object') {
            errors.push(`werewolf.${section} is missing or not an object.`);
          }
        }

        // Timer minimums
        if (ww.timers) {
          if ((ww.timers.nightDuration ?? 0) < 15000)  errors.push("werewolf.timers.nightDuration must be >= 15000 ms.");
          if ((ww.timers.dayDuration ?? 0) < 30000)    errors.push("werewolf.timers.dayDuration must be >= 30000 ms.");
          if ((ww.timers.votingDuration ?? 0) < 15000) errors.push("werewolf.timers.votingDuration must be >= 15000 ms.");
        }

        // Voting tieBreaker enum
        const validTieBreakers = ['no_elimination', 'random'];
        if (ww.voting && !validTieBreakers.includes(ww.voting.tieBreaker)) {
          errors.push(`werewolf.voting.tieBreaker must be one of: ${validTieBreakers.join(', ')}.`);
        }

        // roleDistribution cross-checks
        if (ww.roleDistribution && ww.roles) {
          const knownRoles = Object.keys(ww.roles);
          for (const [playerCount, dist] of Object.entries(ww.roleDistribution)) {
            const count = Number(playerCount);

            if (count < (ww.minPlayers ?? 4) || count > (ww.maxPlayers ?? 20)) {
              warnings.push(`werewolf.roleDistribution key "${playerCount}" is outside player range — will be ignored.`);
              continue;
            }

            let specialTotal = 0;
            let hasWerewolf = false;

            for (const [roleName, roleCount] of Object.entries(dist)) {
              if (!knownRoles.includes(roleName)) {
                errors.push(`werewolf.roleDistribution[${playerCount}] references unknown role "${roleName}".`);
              }
              if (!Number.isInteger(roleCount) || roleCount < 1) {
                errors.push(`werewolf.roleDistribution[${playerCount}].${roleName} must be a positive integer.`);
              }
              specialTotal += roleCount || 0;
              if (roleName === 'werewolf') hasWerewolf = true;
            }

            if (!hasWerewolf) {
              errors.push(`werewolf.roleDistribution[${playerCount}] must include at least one "werewolf" role.`);
            }
            if (specialTotal >= count) {
              errors.push(`werewolf.roleDistribution[${playerCount}] has ${specialTotal} special roles but only ${count} players — at least 1 Villager slot required.`);
            }
          }
        }

        // Narrator keys
        if (ww.narrator) {
          const requiredNarratorKeys = [
            'gameStart', 'nightStart', 'dayStart', 'noKillNight', 'killNight',
            'voteStart', 'voteTie', 'voteEliminate', 'voteSkip',
            'werewolfWin', 'villageWin', 'loversWin',
            'hunterShot', 'witchHeal', 'witchPoison', 'seerReveal',
            'loversLinked', 'heartbreak', 'loversReveal', 'dmFailed', 'actionSkipped',
          ];
          for (const key of requiredNarratorKeys) {
            if (typeof ww.narrator[key] !== 'string' || !ww.narrator[key].trim()) {
              errors.push(`werewolf.narrator.${key} is missing or empty.`);
            }
          }
        }
      }
    }

  } catch (err) {
    // Never let validation itself crash the bot
    errors.push(`Config validation threw an unexpected error: ${err?.message ?? err}`);
  }

  // Log warnings (non-fatal)
  for (const w of warnings) {
    logger.warn(`[Config] ${w}`);
  }

  return errors;
}

// Run validation at startup
const configErrors = validateConfig(botConfig);
if (configErrors.length > 0) {
  logger.error("Bot configuration errors found:\n" + configErrors.map(e => `  • ${e}`).join("\n"));
  if (process.env.NODE_ENV === "production") {
    process.exit(1);
  }
} else {
  logger.info("Bot configuration validated successfully.");
}

export const BotConfig = botConfig;

